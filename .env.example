# 이 파일을 복사해서 ".env" 파일을 만들고, 실제 키 값을 채워 넣으세요.
#   - .env 는 .gitignore 에 등록돼 있어 git/GitHub 에 올라가지 않습니다.
#   - 노트북에서 키가 필요하면 환경변수에서 읽거나, 없으면 실행 시 입력받습니다.
#
# (.env 자동 로드가 필요하면)  pip install python-dotenv  후 노트북에서:
#   from dotenv import load_dotenv; load_dotenv()

OPENAI_API_KEY=
GOOGLE_API_KEY=
UPSTAGE_API_KEY=
TAVILY_API_KEY=
LANGCHAIN_API_KEY=
